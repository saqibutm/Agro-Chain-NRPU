{
  "expo": {
    "name": "AgroChain",
    "slug": "agrochain",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.agrochain.app",
      "buildNumber": "2",
      "infoPlist": {
        "NSCameraUsageDescription": "AgroChain uses the camera to scan product QR codes and to take a profile picture.",
        "NSLocationWhenInUseUsageDescription": "AgroChain records the GPS location of farm harvests and custody transfers for supply-chain traceability.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.agrochain.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ],
      "blockedPermissions": [
        "android.permission.SYSTEM_ALERT_WINDOW"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "extra": {
      "supabaseUrl": "https://jmclztmuewbjcvotnyvh.supabase.co",
      "supabaseAnonKey": "sb_publishable_-VC-zDcIdfODIvnmnmJJqQ_dLnD-gWz",
      "defaultUsername": "appUser"
    },
    "plugins": [
      "./plugins/withStripUnusedIosPermissions.js",
      "./plugins/withAndroidDisableBackup.js",
      "./plugins/withAndroidReleaseSigning.js",
      "./plugins/withFmtConstevalFix.js",
      [
        "expo-camera",
        {
          "cameraPermission": "AgroChain uses the camera to scan product QR codes and to take a profile picture.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "AgroChain records the GPS location of farm harvests and custody transfers for supply-chain traceability."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "AgroChain uses your photo library so you can choose a profile picture.",
          "cameraPermission": "AgroChain uses the camera to scan product QR codes and to take a profile picture.",
          "microphonePermission": false
        }
      ],
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 36
          }
        }
      ],
      "expo-asset",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ]
    ]
  }
}
