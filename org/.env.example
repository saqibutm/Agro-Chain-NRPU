# ── AgroChain Gateway configuration (example) ──
# Copy to "org/.env" and fill in real values. NEVER commit org/.env.
# org/.env is ignored by .gitignore.

# HTTP server
PORT=8081
HOST=0.0.0.0

# Fabric connection profile (place the real file in org/, it is git-ignored)
CONNECTION_PROFILE=connection-org1.json

# Fabric CA / MSP / wallet
CA_NAME=ca.farmerorg1.supplychain.com
ORG_MSP_ID=FarmerOrg1MSP
WALLET_PATH=./walletOrg1

# Channel & chaincode
CHANNEL_NAME=supplychain-channel
CHAINCODE_NAME=supplychain

# CA admin credentials used ONLY by enrollAdminOrg1.js (bootstrap).
# Use the values issued by your Fabric CA. Do not reuse in production without rotation.
CA_ADMIN_ID=admin
CA_ADMIN_SECRET=CHANGE_ME
