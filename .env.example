# ── AgroChain (root) environment example ──
# The mobile app reads its backend URL from app.json -> expo.extra.apiBaseUrl.
# This file documents optional build/CI variables. Copy to ".env" if you wire a
# dotenv-based build step. ".env" is git-ignored.

# Public backend base URL used by production builds (mirror into app.json extra.apiBaseUrl)
API_BASE_URL=https://api.your-domain.example

# Expo / EAS (optional)
EXPO_PUBLIC_API_BASE_URL=https://api.your-domain.example
# EAS_PROJECT_ID is written by `eas build:configure` into app.json (expo.extra.eas.projectId)
